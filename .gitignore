# Fichiers de test - IMAGES
# =============================================================================
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp
*.tiff
*.tif

# =============================================================================
# Fichiers de test - AUDIO
# =============================================================================
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.m4a

# =============================================================================
# Fichiers de test - VIDEO
# =============================================================================
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.m4v

# =============================================================================
# Fichiers de test - DOCUMENTS
# =============================================================================
*.pdf
*.txt

# =============================================================================
# Fichiers sanitizés (générés par l'outil)
# =============================================================================
*_sanitized.*
*_clean.*
*_stripped.*

# =============================================================================
# IDE / Editeurs
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Dossiers de test
